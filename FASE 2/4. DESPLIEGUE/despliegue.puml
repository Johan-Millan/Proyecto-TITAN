@startuml
title Diagrama de Despliegue - Proyecto TITAN

skinparam componentStyle uml2
skinparam node {
    BackgroundColor White
    BorderColor Black
}

' Definición de los nodos de hardware y software

node "Dispositivo Cliente (PC/Smartphone)" <<device>> as Client {
    node "Navegador Web" <<execution environment>> {
        artifact "Frontend (REACT/Tailwind CSS/TypeScript)" as UI
    }
}

node "Servidor de Aplicaciones" <<server>> as AppServer {
    node "Entorno de Ejecución (Node.js/JVM/PHP)" <<execution environment>> as Runtime {
        artifact "TITAN Backend API" as API
        artifact "Módulo de Certificación (PDF/QR)" as CertModule
    }
}

node "Servidor de Base de Datos" <<server>> as DBServer {
    node "SGBD (PostgreSQL/MySQL)" <<execution environment>> as DBMS {
        database "DB_TITAN\n(Usuarios, Cursos, Notas)" as DB
    }
}

node "Servidor de Archivos / Cloud Storage" <<server>> as FileServer {
    artifact "Repositorio de Certificados (PDF)" as PDFDocs
}

cloud "Servicios Externos" {
    node "Servidor SMTP" as EmailService
}

' Relaciones y protocolos
Client -- AppServer : "HTTPS (REST API)"
AppServer -- DBServer : "JDBC / Driver Nativo (Puerto 5432/3306)"
AppServer -- FileServer : "File System / API S3"
AppServer -- EmailService : "SMTP (Notificaciones)"

note right of UI
  Interfaz para Admin,
  Instructores y Consulta
  Pública de Certificados.
end note

note bottom of CertModule
  Genera el PDF con firma
  y código QR de verificación.
end note

@enduml
