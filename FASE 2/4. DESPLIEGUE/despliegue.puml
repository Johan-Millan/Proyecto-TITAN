@startuml
title Diagrama de Despliegue:  Proyecto TITAN

skinparam componentStyle uml2
skinparam node {
    BackgroundColor White
    BorderColor #263238
}

' --- LADO DEL CLIENTE ---
node "Dispositivo del Usuario" <<Device>> as Client {
    node "Web Browser" <<Execution Environment>> {
        artifact "Frontend App (React/TypeScript/Tailwind CSS)" as Frontend
        note right: Consume la API mediante JSON
    }
}

' --- SERVIDOR WEB (Hosting del Frontend) ---
node "Servidor de Contenido Estático" <<Server>> as WebServer {
    artifact "Web Server (Nginx/Apache)" as StaticFiles
}

' --- SERVIDOR DE APLICACIONES (API RESTful) ---
node "Servidor de Aplicaciones" <<Server>> as AppServer {
    node "Runtime ( Java / SpringBoot)" <<Execution Environment>> as Runtime {
        
        package "TITAN API RESTful (Artifact)" {
            component [**Controller Layer**] as Controller <<Component>>
            component [**Service Layer**] as Service <<Component>>
            component [**Repository Layer**] as Repository <<Component>>
            
            Controller -down-> Service : "Lógica de Negocio"
            Service -down-> Repository : "Acceso a Datos"
        }
    }
}

' --- SERVIDOR DE BASE DE DATOS ---
node "Servidor de Base de Datos" <<Server>> as DBServer {
    node "Motor de BD (PostgreSQL/MySQL)" <<Execution Environment>> as DBMS {
        database "TITAN" as DB
    }
}

' --- RELACIONES ---
Client -down-> WebServer : "1. Carga la App (HTTPS)"
Client -down-> Controller : "2. Peticiones REST (JSON/HTTPS)"
Repository -down-> DB : "3. Consultas SQL / NoSQL"

' Notas adicionales
note left of Controller
  Puntos de entrada (Endpoints)
  GET, POST, PUT, DELETE
end note

note left of Service
  Validaciones de seguridad,
  cálculos y reglas de negocio
end note

@enduml
